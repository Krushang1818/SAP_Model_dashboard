# Model-loading values are fallback/legacy defaults. Configure and reload them
# from the localhost-only Model Settings panel after starting PC2.
OFFLINE_LLM_MODEL_DIR=versions/custom-invoice-llm
OFFLINE_BASE_MODEL_PATH=Qwen/Qwen2.5-7B-Instruct
LLM_LOCAL_FILES_ONLY=true
LLM_LOAD_IN_4BIT=true
OFFLINE_LLM_MOCK=false
MODEL_SERVER_PORT=8001

# Optional custom cloudflared executable location.
CLOUDFLARED_PATH=
